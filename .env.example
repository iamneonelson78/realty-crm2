# ---------------------------------------------------------------------------
# Realty CRM — environment variable reference
#
# Copy this file to `.env.local` for local development, and mirror the
# server-side vars into Vercel → Project Settings → Environment Variables for
# Production + Preview. NEVER commit real values.
#
# See docs/EMAIL_SETUP.md for step-by-step setup instructions.
# ---------------------------------------------------------------------------

# ---- Client (browser) — exposed to the bundle, must be prefixed VITE_ ------

# Supabase project URL, e.g. https://dhfjmbqljsqkgixbkgkd.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key. Safe to expose — RLS policies must enforce access.
VITE_SUPABASE_ANON_KEY=

# ---- Server-only (Vercel serverless functions) -----------------------------
# These MUST NOT be prefixed with VITE_, otherwise Vite will inline them into
# the browser bundle and leak the service role key.

# Resend API key (sending-scoped). Create at https://resend.com/api-keys
RESEND_API_KEY=

# Friendly sender identity. Domain portion must be verified in Resend.
# Example: "Realty CRM <noreply@getcoreviatechnologies.com>"
FROM_EMAIL=

# Same URL as VITE_SUPABASE_URL but without the VITE_ prefix — serverless
# functions read this when instantiating the admin client.
SUPABASE_URL=

# Supabase service_role key. Server-only — treat like a root password.
# Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret generated by Supabase when you enable the Send Email Hook.
# Value looks like `v1,whsec_...`. Used to verify inbound webhook signatures.
SEND_EMAIL_HOOK_SECRET=

# Inbox that receives "new signup awaiting approval" notifications.
ADMIN_EMAIL=

# Public URL of the deployed app, used to build links inside outbound emails.
# No trailing slash. Example: https://realty-crm2.vercel.app
APP_URL=
