# ----- Server-only (Vercel serverless functions under /api/*) -----
# NEVER prefix these with VITE_ — that would leak them to the browser.

# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_SiBrWPen_4....
# Must be a verified sender on a domain you own in Resend.
FROM_EMAIL=Realty CRM <support@getcoreviatechnologies.com>

# Supabase service role key (Project Settings -> API -> service_role).
# Used server-side to verify tokens and fetch profile rows.
SUPABASE_URL=https://dhfjmbqljsqkgixbkgkd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...
# Supabase "Send Email" auth hook secret. Shown once when you set the hook URL.
# Starts with v1,whsec_
SEND_EMAIL_HOOK_SECRET=v1,whsec_6.....

# Where to send admin notifications + build links in outbound emails.
ADMIN_EMAIL=support@getcoreviatechnologies.com
APP_URL=https://realty-crm-preview.getcoreviatechnologies.com

